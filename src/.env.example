# Docker Compose override values for local development.
# Copy this file to src/.env if you need to change the default ports or API URL.

UI_HOST_BIND=127.0.0.1
UI_HOST_PORT=5173
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://api:8000

WEB_HOST_BIND=127.0.0.1
WEB_HOST_PORT=8080

API_HOST_BIND=127.0.0.1
API_HOST_PORT=8000
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
OPENTUBE_DEFAULT_OWNER_USERNAME=local-researcher

POSTGRES_HOST_BIND=127.0.0.1
POSTGRES_HOST_PORT=5432
